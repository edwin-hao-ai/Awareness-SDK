{
  "id": "openclaw-memory",
  "name": "Awareness Memory",
  "version": "0.1.8",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiKey": { "type": "string", "default": "" },
      "baseUrl": { "type": "string", "default": "https://awareness.market/api/v1" },
      "memoryId": { "type": "string", "default": "" },
      "agentRole": { "type": "string", "default": "builder_agent" },
      "autoRecall": { "type": "boolean", "default": true },
      "autoCapture": { "type": "boolean", "default": true },
      "recallLimit": { "type": "integer", "default": 8 }
    }
  },
  "uiHints": {
    "apiKey": { "label": "Awareness API Key", "sensitive": true },
    "memoryId": { "label": "Memory ID" }
  }
}
