{
  "mcpServers": {
    "awareness-memory": {
      "type": "http",
      "url": "${AWARENESS_MCP_URL:-https://awareness.market/mcp}",
      "headers": {
        "Authorization": "Bearer ${AWARENESS_API_KEY}",
        "X-Awareness-Memory-Id": "${AWARENESS_MEMORY_ID}",
        "X-Awareness-Agent-Role": "${AWARENESS_AGENT_ROLE:-builder_agent}",
        "X-Awareness-Source": "claude-code"
      }
    }
  }
}
